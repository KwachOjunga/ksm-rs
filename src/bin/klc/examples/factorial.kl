func main(n) {
    const v = factorial(n);
    return v;
}

func fib(n) {
    if (n < 2) {
        return n;
    } else {
        return fib(n - 1) + fib(n - 2);
    }
}

func factorial(n) {
    const result = 1;
    const i = 0;
    i = n;
    while (i > 0) {
        result = result * i;
        i = i - 1;
    }
    return result;
}
