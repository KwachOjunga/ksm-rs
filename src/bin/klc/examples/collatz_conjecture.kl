// ::NOTE:: - This highlights the absence of a modulus operator

func Collatz(n) {
    const steps = 0;
	while n > 1 {
		if n%2 == 0 {
			n = n / 2;
		} else {
			n = 3*n + 1;
		}
		// fmt.Printf("-> %d ", n)
		++steps;
	}

	return steps;
}

func main(startNumber) {
	const totalSteps  = Collatz(startNumber);
	return totalSteps;
}
